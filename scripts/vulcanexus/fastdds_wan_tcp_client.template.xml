<?xml version="1.0" encoding="UTF-8" ?>
<profiles xmlns="http://www.eprosima.com/XMLSchemas/fastRTPS_Profiles">
    <transport_descriptors>
        <transport_descriptor>
            <transport_id>CHANGE_ME_TRANSPORT_ID</transport_id>
            <type>TCPv4</type>
            <listening_ports>
                <port>CHANGE_ME_LISTEN_PORT</port>
            </listening_ports>
            <wan_addr>CHANGE_ME_CLIENT_WAN_ADDR</wan_addr>
        </transport_descriptor>
    </transport_descriptors>

    <participant profile_name="CHANGE_ME_PROFILE_NAME" is_default_profile="true">
        <rtps>
            <userTransports>
                <transport_id>CHANGE_ME_TRANSPORT_ID</transport_id>
            </userTransports>
            <useBuiltinTransports>false</useBuiltinTransports>
            <builtin>
                <discovery_config>
                    <discoveryProtocol>CLIENT</discoveryProtocol>
                    <discoveryServersList>
                        <RemoteServer prefix="CHANGE_ME_SERVER_GUID_PREFIX">
                            <metatrafficUnicastLocatorList>
                                <locator>
                                    <tcpv4>
                                        <address>CHANGE_ME_SERVER_WAN_ADDR</address>
                                        <port>CHANGE_ME_SERVER_PORT</port>
                                        <physical_port>CHANGE_ME_SERVER_PORT</physical_port>
                                    </tcpv4>
                                </locator>
                            </metatrafficUnicastLocatorList>
                        </RemoteServer>
                    </discoveryServersList>
                </discovery_config>
            </builtin>
        </rtps>
    </participant>
</profiles>
